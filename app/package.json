{
  "name": "EagleScout",
  "version": "8.0.0",
  "main": "index.tsx",
  "private": true,
  "scripts": {
    "postinstall": "patch-package && npm run codegen",
    "test": "jest",
    "start": "expo start",
    "prebuild": "expo prebuild --clean",
    "android": "npm run prebuild && expo run:android",
    "ios": "npm run prebuild && expo run:ios",
    "lint": "expo lint",
    "codegen": "./scripts/codegen.sh",
    "bundle": "npm run bundle:android && npm run bundle:ios",
    "bundle:android": "npx expo export:embed --platform android --dev false --reset-cache --bundle-output ./dist/android/main.jsbundle --assets-dest ./dist/android --bytecode",
    "bundle:ios": "npx expo export:embed --platform ios --dev false --reset-cache --bundle-output ./dist/ios/main.jsbundle --assets-dest ./dist/ios --bytecode",
    "publish-bundle": "./scripts/publish-bundle.sh"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "@floating-ui/react-native": "^0.10.9",
    "@gorhom/bottom-sheet": "^5.2.8",
